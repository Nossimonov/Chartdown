{
  "name": "chartdown-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Chartdown reference implementation workspace — see ADR 0007",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p packages/core && tsc --noEmit -p packages/render-svg"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
