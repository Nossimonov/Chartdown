{
  "name": "@chartdown/render-svg",
  "version": "0.2.1",
  "description": "Chartdown SVG renderer — deterministic, seeded, themeable rendering of plain-text TTRPG maps. Runtime-dependency-free beyond @chartdown/core (ADR 0007).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "chartdown",
    "ttrpg",
    "map",
    "battlemap",
    "hexcrawl",
    "svg",
    "renderer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nossimonov/Chartdown.git",
    "directory": "packages/render-svg"
  },
  "homepage": "https://nossimonov.github.io/Chartdown/",
  "bugs": "https://github.com/Nossimonov/Chartdown/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@chartdown/core": "0.2.1"
  }
}
